{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-watch",
    { "identifier": "fs:scope", "allow": [{ "path": "$HOME/**" }, { "path": "**" }] },
    "dialog:allow-open",
    "store:allow-load",
    "store:allow-set",
    "store:allow-get",
    "store:allow-save"
  ]
}
